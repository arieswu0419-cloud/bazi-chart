rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 系統維護帳號：寫死單一 email，用 Firebase Auth 驗證過的 token email 判斷（不是查 Firestore 資料，
    // 避免「要先讀資料才能判斷有沒有權限讀資料」的循環問題，也不怕使用者自己竄改 Firestore 文件把自己設成管理者）
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'arieswu0419@gmail.com';
    }

    match /users/{userId} {
      // 本人可以讀自己的審核狀態／權限；管理者可以讀（含列表查詢）所有人的資料
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());

      // 註冊時只能建立自己的資料，且狀態必須是 pending（不能自己核准自己），
      // 權限九個功能一律從關閉開始，要管理者登入後台手動開啟
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.status == 'pending'
                    && request.resource.data.email is string
                    && request.resource.data.name is string
                    && request.resource.data.permissions == {
                         'bazi': false, 'renge': false, 'lifenum': false, 'qimen': false,
                         'qimenDunjia': false, 'guanyin': false, 'jigong': false, 'fengshui': false, 'mingpian': false
                       };

      // 一般使用者不能自行修改審核狀態或權限；只有管理者可以修改（審核帳號、開關九個功能的權限）
      allow update: if isAdmin();
      allow delete: if false;
    }
  }
}
